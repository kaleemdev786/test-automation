APP_NAME=BugTicketSystem
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bug_tickets
DB_USERNAME=root
DB_PASSWORD=



# Queue driver — use 'database' for simple setup, 'redis' for production
QUEUE_CONNECTION=database

FILESYSTEM_DISK=local

# ── Git Automation ──────────────────────────────────────────────────────────
# IMPORTANT: Use FORWARD SLASHES for Windows paths (backslashes break .env parsing)
# Absolute path to the repo the AI will patch
BUG_TICKET_REPO_PATH="C:/path/to/your-laravel-project"

# GitHub/GitLab remote HTTPS URL (without credentials)
BUG_TICKET_GIT_REMOTE_URL=https://github.com/kaleemdev786/test-automation

# Personal Access Token with repo write permission
BUG_TICKET_GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub/GitLab username
BUG_TICKET_GIT_USERNAME=kaleemdev786

# Base branch to merge fixes into
BUG_TICKET_BASE_BRANCH=main

# Auto-merge the fix branch into base branch? true/false
BUG_TICKET_AUTO_MERGE=true

# Identity used for git commits
BUG_TICKET_GIT_AUTHOR_NAME=Bug Ticket Bot
BUG_TICKET_GIT_AUTHOR_EMAIL=bot@bug-tickets.local
